@article{li_density_2025,
  title = {A Density Extrapolation Method for Noncubic Equations of State},
  volume = {65},
  url = {https://pubs.acs.org/doi/full/10.1021/acs.iecr.5c04076},
  doi = {10.1021/acs.iecr.5c04076},
  abstract = {Fluid phase equilibrium calculations are essential for determining system thermodynamic states and underpin chemical process simulations. Iterative calculations in infeasible phase regions may lead to trivial solutions or convergence failure. Existing extrapolation strategies are mostly limited to cubic equations of state (CEoS) and rely on analytical mechanical critical points, restricting their application to higher-order, nonanalytical EoS such as PC-SAFT. To address this, we introduce a general density extrapolation method applicable to EoS without closed-form solutions. The method employs robust numerical techniques to determine the starting point of density extrapolation and the mechanical critical point, thereby developing a more stable approach for vapor phase density extrapolation to estimate densities in infeasible phase regions. Validation through several phase equilibrium cases using the PC-SAFT EoS demonstrates that this method is efficient in terms of convergence and robust for nonlinear and noncubic EoS.},
  language = {en},
  number = {1},
  journal = {Industrial \& Engineering Chemistry Research},
  publisher = {American Chemical Society},
  author = {Li, Hongrui and Hong, Xiaodong and Wang, Jingdai and Yang, Yongrong and Liao, Zuwei},
  month = dec,
  year = {2025},
  pages = {688--699}
}
